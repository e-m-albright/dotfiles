{
  "hooks": [
    {
      "event": "afterFileEdit",
      "command": "~/dotfiles/ai/agents/cursor/hooks/format-on-save-shim.sh",
      "matcher": "*.sh|*.ts|*.tsx|*.js|*.jsx|*.py|*.rs|*.go|*.json"
    },
    {
      "event": "beforeShellExecution",
      "command": "~/dotfiles/ai/agents/cursor/hooks/guard-destructive.sh",
      "matcher": "*"
    }
  ]
}
