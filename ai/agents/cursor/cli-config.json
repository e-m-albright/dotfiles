{
  "version": 1,
  "editor": { "vimMode": false },
  "permissions": {
    "allow": [
      "Shell(git)",
      "Shell(npm)",
      "Shell(bun)",
      "Shell(go)",
      "Shell(cargo)",
      "Shell(just)",
      "Shell(dotfiles)",
      "Shell(shellcheck)",
      "Shell(lefthook)",
      "Read(**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(*.md)"
    ],
    "deny": [
      "Shell(rm -rf /)",
      "Shell(rm -rf)",
      "Shell(sudo)",
      "Shell(su)",
      "Shell(dd)",
      "Shell(mkfs)",
      "Shell(chmod 777)",
      "Shell(git push --force)",
      "Shell(git reset --hard)",
      "Shell(git clean)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/credentials*)",
      "Write(**/*id_rsa*)",
      "Write(**/*id_ed25519*)"
    ]
  },
  "attribution": {
    "attributeCommitsToAgent": true,
    "attributePRsToAgent": true
  }
}
