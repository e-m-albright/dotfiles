{
  "scope": "cli/src/dotfiles (non-test)",
  "files_glob": "src/**/*.py",
  "run_from": "cli/",
  "updated": "2026-06-07",
  "policy": "Monotonic ratchet — every ceiling may only DECREASE. Raising one needs a Ratchet-Bump trailer + reason. See docs/knowledge/engineering-gates.md §1. Check with the improve-codebase-architecture skill's scripts/ratchet-check.sh.",
  "loc_nontest": 9010,
  "complexity": {
