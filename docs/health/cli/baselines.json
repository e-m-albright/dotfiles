  },
  "suppression_patterns": {
    "type-ignore": "# *type: *ignore",
    "cast": "cast\\(",
    "any-annotation": ": Any\\b|dict\\[str, Any\\]",
    "noqa": "# *noqa",
    "broad-except": "except Exception",
    "pragma-no-cover": "# *pragma: *no cover"
  }
