// Zed settings — managed in dotfiles (symlinked to ~/.config/zed/settings.json)
//
// External agents (ACP) run each vendor's own CLI and use its SUBSCRIPTION
// login — NOT a pay-per-use API key. Start a thread from the agent panel
// (cmd-?) and authenticate in-thread:
//   claude-acp → /login → "Log in with Claude Code"  (Max subscription)
//   codex-acp  → "Login with ChatGPT"                 (ChatGPT subscription)
// The "agent.default_model" / "inline_assistant_model" below are the SEPARATE
// built-in providers — those DO use API keys (billed per token).
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent": {
    // Terminal approvals for Claude/Codex ACP sessions launched through Zed are
    // governed here, not by each agent's own config. Zed's
    // order is: built-in security -> always_deny -> always_allow -> default.
    // We keep default "allow" for flow and retain this small destructive-command
    // floor locally because Zed owns this permission surface.
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
          "always_deny": [
            { "pattern": "(^|[;&|]|&&)\\s*sudo\\b" },
            { "pattern": "(^|[;&|]|&&)\\s*su\\b" },
            { "pattern": "\\brm\\s+(-[a-zA-Z]*\\s+)*-?[a-zA-Z]*[rf]" },
            { "pattern": "(^|[;&|]|&&)\\s*dd\\b" },
            { "pattern": "\\bmkfs(\\.|\\b)" },
            { "pattern": "\\bdiskutil\\s+(erase|partitionDisk)\\b" },
            { "pattern": "\\bchmod\\s+(-[a-zA-Z]*\\s+)*(777|-R)\\b" },
            { "pattern": "\\bgit\\s+push\\b.*(--force|-f)\\b" },
            { "pattern": "\\bgit\\s+reset\\s+--hard\\b" },
            { "pattern": "\\bgit\\s+clean\\b" },
            { "pattern": "\\bgit\\s+branch\\s+-D\\b" },
            { "pattern": "\\b(curl|wget)\\b[^|]*\\|\\s*(ba)?sh\\b" },
            { "pattern": "\\bkillall\\b" },
            { "pattern": "\\bpkill\\b" },
            { "pattern": ":\\s*\\(\\s*\\)\\s*\\{\\s*:\\s*\\|\\s*:" }
          ]
        }
      }
    },
    "dock": "left",
    "play_sound_when_agent_done": "always",
    "default_model": {
      "enable_thinking": false,
      "provider": "lmstudio",
      "model": "qwen3.6-35b-a3b"
    },
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest"
    }
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night Storm"
  }
}
