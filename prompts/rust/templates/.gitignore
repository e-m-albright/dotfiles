# =============================================================================
# Rust Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
/target/

# -----------------------------------------------------------------------------
# Cargo Lock
# -----------------------------------------------------------------------------
# Keep Cargo.lock for binaries/services — it ensures reproducible builds.
# Remove this line if building a library (crates.io convention is to not commit).
# Cargo.lock

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
# VS Code
.vscode/

# JetBrains (RustRover / CLion)
.idea/

# Vim
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
/lcov.info
/tarpaulin-report.html
*.profdata
*.profraw
/coverage/

# -----------------------------------------------------------------------------
# Benchmarks
# -----------------------------------------------------------------------------
/criterion/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# AI Tools
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Agent Artifacts
# -----------------------------------------------------------------------------
.agents/
!.agents/decisions/

# -----------------------------------------------------------------------------
# Project Specific
# -----------------------------------------------------------------------------
# Add project-specific ignores here
