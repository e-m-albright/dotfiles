# Global direnv config — symlinked to ~/.config/direnv/direnvrc by install.sh.
# Defines reusable `layout` helpers so per-project .envrc files stay one-liners.

# layout uv — activate a uv-managed virtualenv (./.venv) for the project.
#
# Usage: drop `layout uv` in a project's .envrc, then run `direnv allow` once.
# On entry direnv exports VIRTUAL_ENV + prepends .venv/bin to PATH (which the
# amuse.zsh-theme surfaces as `[.venv]`); on exit it tears both back down.
#
# Pass a custom path as the first arg if the venv isn't at ./.venv:
#   layout uv .venvs/api
layout_uv() {
	local venv="${1:-.venv}"
	if [[ ! -d "$venv" ]]; then
		log_error "layout uv: no '$venv' here — run 'uv venv' (or 'uv sync') first."
		return 1
	fi
	VIRTUAL_ENV="$(expand_path "$venv")"
	PATH_add "$VIRTUAL_ENV/bin"
	export VIRTUAL_ENV
}
