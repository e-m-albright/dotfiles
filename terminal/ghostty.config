# Ghostty terminal configuration
# Symlinked to ~/.config/ghostty/config by install.sh

# Notifications — enables OSC 9/777 desktop notifications
# Claude Code uses these when waiting for input
desktop-notifications = true

# Theme
theme = Dracula

# Font
font-size = 14

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true

# Shell integration
shell-integration = zsh

# Window/tab state restoration
# `always` saves state on every quit so a relaunch (or system reboot)
# reopens the same windows, tabs, splits, and working directories.
# State lives in ~/Library/Saved Application State/com.mitchellh.ghostty.savedState/
# Caveats: tab titles aren't preserved; an unexpected power loss / kernel panic
# may not flush state. For graceful quits and normal reboots this works.
window-save-state = always

# New tabs/windows inherit the cwd of the focused tab (helps post-restore too)
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
