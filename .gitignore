# =============================================================================
# Dotfiles Repository Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Tool Caches
# -----------------------------------------------------------------------------
.claude/
.cursor/hooks/state/
.crush/
.direnv/
cli/.complexipy_cache/

# -----------------------------------------------------------------------------
# Agent-generated markdown (scrub with `just scrub --artifacts`)
# -----------------------------------------------------------------------------
docs/adr/
docs/specs/
docs/plans/
docs/superpowers/

# -----------------------------------------------------------------------------
# Repo-local agent tooling (canonical: ai/.agents/)
# -----------------------------------------------------------------------------
.agents/
ai/.agents/plans/
ai/.agents/research/
ai/.agents/sessions/
ai/.agents/prompts/
ai/.agents/decisions/

# -----------------------------------------------------------------------------
# Obsidian (canonical copy lives in editors/obsidian/)
# -----------------------------------------------------------------------------
community-plugins.json

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace

# -----------------------------------------------------------------------------
# Local Configuration (user-specific, not shared)
# -----------------------------------------------------------------------------
*.local
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log

# -----------------------------------------------------------------------------
# Generated by agents/cursor/setup.sh from agents/shared/
# -----------------------------------------------------------------------------
agents/cursor/rules/
editors/cursor/.cursorignore

# -----------------------------------------------------------------------------
# Ephemeral agent working files (durable artifacts go in docs/)
# See: docs/knowledge/agent-output.md
# -----------------------------------------------------------------------------
ai/artifacts/

# Raw adversarial-assessor output (`just assess`). Generated, may be large and
# numerous; copy a curated assessment into docs/health/<scope>/ deliberately.
docs/health/assessments/

# -----------------------------------------------------------------------------
# Vendor CLI cwd state (created when running gemini/codex/pi from within dotfiles)
# -----------------------------------------------------------------------------
.gemini/
.pi/

# tools/ -- per-tool virtualenvs and caches
tools/*/.venv/
tools/*/.ruff_cache/
tools/*/__pycache__/
tools/*/yt_ingest/__pycache__/

# Python CLI (cli/) build + tool caches
cli/.venv/
cli/.ruff_cache/
cli/.pytest_cache/
cli/.coverage
cli/htmlcov/
cli/**/__pycache__/
cli/snapshot_report.html
