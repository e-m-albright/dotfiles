# =============================================================================
# Dotfiles Repository Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Tool Caches
# -----------------------------------------------------------------------------
.claude/
.cursor/hooks/state/

# -----------------------------------------------------------------------------
# Superpowers (external plugin, not part of dotfiles)
# -----------------------------------------------------------------------------
docs/superpowers/

# -----------------------------------------------------------------------------
# Obsidian (canonical copy lives in editors/obsidian/)
# -----------------------------------------------------------------------------
community-plugins.json

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace

# -----------------------------------------------------------------------------
# Local Configuration (user-specific, not shared)
# -----------------------------------------------------------------------------
*.local
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log

# -----------------------------------------------------------------------------
# Generated by agents/cursor/setup.sh from agents/shared/
# -----------------------------------------------------------------------------
agents/cursor/rules/
editors/cursor/.cursorignore

# -----------------------------------------------------------------------------
# Ephemeral agent working files (durable artifacts go in docs/)
# See: .ai/rules/process/artifact-placement.mdc
# -----------------------------------------------------------------------------
.ai/artifacts/

# -----------------------------------------------------------------------------
# In-flight specs/plans — kept local, not published. Durable rationale
# graduates into docs/ (ADRs, guides); the working spec stays on disk only.
# -----------------------------------------------------------------------------
docs/specs/
docs/plans/

# -----------------------------------------------------------------------------
# Vendor CLI cwd state (created when running gemini/codex/pi from within dotfiles)
# -----------------------------------------------------------------------------
.gemini/
.pi/

# tools/ -- per-tool virtualenvs and caches
tools/*/.venv/
tools/*/.ruff_cache/
tools/*/__pycache__/
tools/*/yt_ingest/__pycache__/

# Python CLI (cli/) build + tool caches
cli/.venv/
cli/.ruff_cache/
cli/.pytest_cache/
cli/.coverage
cli/htmlcov/
cli/**/__pycache__/
