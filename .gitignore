# =============================================================================
# Dotfiles Repository Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Tool Caches
# -----------------------------------------------------------------------------
.claude/
.cursor/hooks/state/

# -----------------------------------------------------------------------------
# Superpowers (external plugin, not part of dotfiles)
# -----------------------------------------------------------------------------
docs/superpowers/

# -----------------------------------------------------------------------------
# Obsidian (canonical copy lives in editors/obsidian/)
# -----------------------------------------------------------------------------
community-plugins.json

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-workspace

# -----------------------------------------------------------------------------
# Local Configuration (user-specific, not shared)
# -----------------------------------------------------------------------------
*.local
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log

# -----------------------------------------------------------------------------
# Generated by agents/cursor/setup.sh from agents/shared/
# -----------------------------------------------------------------------------
agents/cursor/rules/
editors/cursor/.cursorignore

# -----------------------------------------------------------------------------
# Ephemeral agent working files (durable artifacts go in docs/)
# See: .ai/rules/process/artifact-placement.mdc
# -----------------------------------------------------------------------------
.ai/artifacts/
