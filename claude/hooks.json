{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/format-on-save.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code · $(basename \"$PWD\")\" -message 'Done — ready for input' -sound Glass 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code · $(basename \"$PWD\")\" -message 'Permission needed' -sound Basso 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
