#!/usr/bin/env bash

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1

ARROW="￫"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Get dotfiles dir (so run this script from anywhere)
export DOTFILES_DIR EXTRA_DIR
DOTFILES_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && cd .. && pwd )"

sub_help () {
    printf "%s Usage: ${YELLOW}%s <command>${NC}\n" "$ARROW" "$BIN_NAME"
    printf "\n"
    printf "Commands:\n"
    printf "   install          Run full dotfiles setup (install.sh)\n"
    printf "   help             This help message\n"
    printf "   doctor           Check that all tools are installed correctly\n"
    printf "   update           Update OS, Homebrew, and Node.js LTS\n"
    printf "   clean            Clean up Homebrew caches\n"
    printf "   brew             Run Homebrew setup script\n"
    printf "   dock             Reset macOS Dock layout\n"
    printf "   stale            Find disabled packages still installed\n"
    printf "   profile-shell    Profile shell startup time\n"
    printf "   scaffold         Scaffold a new project with AI rules\n"
    printf "   claude-setup         Configure Claude Code (plugins, voice, instructions)\n"
    printf "   claude-instructions  Update ~/.claude/CLAUDE.md with AGENTS.md reference\n"
    printf "   completions      Output shell completions (source this in your shell)\n"
}

sub_doctor () {
    printf "${BLUE}%s Checking dotfiles installation...${NC}\n\n" "$ARROW"

    local all_ok=true

    # Check function
    check_tool() {
        local name="$1"
        local cmd="$2"
        local install_hint="$3"

        if command -v "$cmd" >/dev/null 2>&1; then
            local version
            version=$("$cmd" --version 2>/dev/null | head -1 || echo "installed")
            printf "  ${GREEN}✓${NC} %-20s %s\n" "$name" "$version"
        else
            printf "  ${RED}✗${NC} %-20s ${YELLOW}%s${NC}\n" "$name" "$install_hint"
            all_ok=false
        fi
    }

    printf "${BLUE}Core Tools${NC}\n"
    check_tool "Homebrew" "brew" "Run install.sh"
    check_tool "Git" "git" "brew install git"
    check_tool "jq" "jq" "brew install jq"
    check_tool "yq" "yq" "brew install yq"

    printf "\n${BLUE}Editors${NC}\n"
    check_tool "Cursor" "cursor" "brew install --cask cursor"

    printf "\n${BLUE}Runtimes${NC}\n"
    check_tool "Bun" "bun" "curl -fsSL https://bun.sh/install | bash"
    check_tool "FNM" "fnm" "curl -fsSL https://fnm.vercel.app/install | bash"
    check_tool "UV" "uv" "curl -LsSf https://astral.sh/uv/install.sh | sh"
    check_tool "Go" "go" "brew install go"

    # Check Node.js via fnm
    if command -v fnm >/dev/null 2>&1; then
        if fnm list 2>/dev/null | grep -q "lts-latest\|v"; then
            local node_version
            node_version=$(node --version 2>/dev/null || echo "not active")
            printf "  ${GREEN}✓${NC} %-20s %s\n" "Node.js" "$node_version"
        else
            printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run: fnm install --lts${NC}\n" "Node.js"
        fi
    fi

    # Check Python via uv
    if command -v python3.14 >/dev/null 2>&1; then
        printf "  ${GREEN}✓${NC} %-20s %s\n" "Python" "$(python3.14 --version 2>/dev/null)"
    elif command -v python3 >/dev/null 2>&1; then
        printf "  ${YELLOW}○${NC} %-20s %s ${YELLOW}(consider: uv python install 3.14)${NC}\n" "Python" "$(python3 --version 2>/dev/null)"
    else
        printf "  ${RED}✗${NC} %-20s ${YELLOW}Run: uv python install 3.14${NC}\n" "Python"
        all_ok=false
    fi

    printf "\n${BLUE}AI Tools${NC}\n"
    check_tool "Claude Code" "claude" "brew install claude-code"

    printf "\n${BLUE}Dev Tools${NC}\n"
    check_tool "Just" "just" "brew install just"
    check_tool "Delta" "delta" "brew install git-delta"
    check_tool "golangci-lint" "golangci-lint" "brew install golangci-lint"

    printf "\n${BLUE}Configuration${NC}\n"
    # Check symlinks
    if [[ -L ~/.zshrc ]] && [[ "$(readlink ~/.zshrc)" == *"dotfiles"* ]]; then
        printf "  ${GREEN}✓${NC} %-20s symlinked\n" ".zshrc"
    else
        printf "  ${YELLOW}○${NC} %-20s ${YELLOW}not symlinked to dotfiles${NC}\n" ".zshrc"
    fi

    if [[ -L ~/.gitconfig ]] && [[ "$(readlink ~/.gitconfig)" == *"dotfiles"* ]]; then
        printf "  ${GREEN}✓${NC} %-20s symlinked\n" ".gitconfig"
    else
        printf "  ${YELLOW}○${NC} %-20s ${YELLOW}not symlinked to dotfiles${NC}\n" ".gitconfig"
    fi

    if [[ -f ~/.gitconfig.local ]]; then
        printf "  ${GREEN}✓${NC} %-20s configured\n" "Git identity"
    else
        printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run install.sh to set up${NC}\n" "Git identity"
    fi

    if [[ -f ~/.claude/CLAUDE.md ]]; then
        printf "  ${GREEN}✓${NC} %-20s exists\n" "Claude memory"
    else
        printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run: dotfiles claude-instructions${NC}\n" "Claude memory"
    fi

    if [[ -f ~/.claude/settings.json ]] && command -v jq >/dev/null 2>&1; then
        local plugin_count
        plugin_count=$(jq '.enabledPlugins // {} | length' ~/.claude/settings.json 2>/dev/null || echo "0")
        if [[ "$plugin_count" -gt 0 ]]; then
            printf "  ${GREEN}✓${NC} %-20s %s plugins enabled\n" "Claude plugins" "$plugin_count"
        else
            printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run: dotfiles claude-setup${NC}\n" "Claude plugins"
        fi

        local hook_count
        hook_count=$(jq '.hooks // {} | keys | length' ~/.claude/settings.json 2>/dev/null || echo "0")
        if [[ "$hook_count" -gt 0 ]]; then
            printf "  ${GREEN}✓${NC} %-20s %s events configured\n" "Claude hooks" "$hook_count"
        else
            printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run: dotfiles claude-setup${NC}\n" "Claude hooks"
        fi
    fi

    if [[ -f ~/.claude.json ]] && command -v jq >/dev/null 2>&1; then
        local mcp_count
        mcp_count=$(jq '.mcpServers // {} | length' ~/.claude.json 2>/dev/null || echo "0")
        if [[ "$mcp_count" -gt 0 ]]; then
            printf "  ${GREEN}✓${NC} %-20s %s servers\n" "Claude MCP" "$mcp_count"
        else
            printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run: dotfiles claude-setup${NC}\n" "Claude MCP"
        fi
    fi

    if [[ -f ~/.config/ghostty/config ]]; then
        printf "  ${GREEN}✓${NC} %-20s configured\n" "Ghostty"
    elif [[ -d "/Applications/Ghostty.app" ]]; then
        printf "  ${YELLOW}○${NC} %-20s ${YELLOW}Run install.sh to configure${NC}\n" "Ghostty"
    fi

    printf "\n"
    if $all_ok; then
        printf "${GREEN}%s All checks passed!${NC}\n" "$ARROW"
    else
        printf "${YELLOW}%s Some tools are missing. Run install.sh or install individually.${NC}\n" "$ARROW"
    fi
}

sub_update () {
    sudo softwareupdate -i -a
    brew update
    brew upgrade

    # Update Node.js to latest LTS via fnm
    if command -v fnm >/dev/null 2>&1; then
        eval "$(fnm env)"
        fnm install --lts
        fnm use --install-if-missing lts-latest
        fnm default lts-latest
    fi

    printf "${GREEN}%s Success! Update command finished.${NC}\n" "$ARROW"
}

sub_clean () {
    brew cleanup
    printf "${GREEN}%s Success! Clean command finished.${NC}\n" "$ARROW"
}

sub_brew () {
    . "$DOTFILES_DIR/macos/brew.sh"
    printf "${GREEN}%s Success! Brew command finished.${NC}\n" "$ARROW"
}

sub_dock () {
    . "$DOTFILES_DIR/macos/dock.sh"
    printf "${GREEN}%s Success! MacOS dock command finished.${NC}\n" "$ARROW"
}

sub_claude_instructions() {
    "$DOTFILES_DIR/macos/claude_instructions.sh"
    printf "${GREEN}%s Claude system instructions updated (~/.claude/CLAUDE.md).${NC}\n" "$ARROW"
}

sub_claude_setup() {
    . "$DOTFILES_DIR/claude/setup.sh"
    printf "${GREEN}%s Claude Code setup complete.${NC}\n" "$ARROW"
}

sub_stale() {
    printf "${BLUE}%s Checking for stale artifacts...${NC}\n\n" "$ARROW"

    # Check for brew packages that were disabled but might still be installed
    printf "${BLUE}Disabled brew packages still installed:${NC}\n"
    local found=false
    local disabled_pkgs=(
        "visual-studio-code" "iterm2" "warp" "docker-desktop"
        "terraform" "signal" "discord" "super-productivity"
        "ollama" "gemini-cli"
    )
    for pkg in "${disabled_pkgs[@]}"; do
        if brew list "$pkg" &>/dev/null 2>&1 || brew list --cask "$pkg" &>/dev/null 2>&1; then
            printf "  ${YELLOW}○${NC} %-25s ${YELLOW}brew uninstall %s${NC}\n" "$pkg" "$pkg"
            found=true
        fi
    done
    if ! $found; then
        printf "  ${GREEN}✓${NC} No stale packages found\n"
    fi

    # Check for stale symlinks in home directory
    printf "\n${BLUE}Broken symlinks in ~/:${NC}\n"
    local broken=false
    for link in ~/.zshrc ~/.zprofile ~/.zshenv ~/.gitconfig ~/.gitignore_global; do
        if [[ -L "$link" ]] && [[ ! -e "$link" ]]; then
            printf "  ${RED}✗${NC} %s → %s (broken)\n" "$link" "$(readlink "$link")"
            broken=true
        fi
    done
    if ! $broken; then
        printf "  ${GREEN}✓${NC} All symlinks valid\n"
    fi

    # Check for old VS Code config remnants
    printf "\n${BLUE}Old editor configs:${NC}\n"
    local old=false
    if [[ -d ~/Library/Application\ Support/Code/User ]] && \
       [[ -L ~/Library/Application\ Support/Code/User/settings.json ]] && \
       [[ "$(readlink ~/Library/Application\ Support/Code/User/settings.json 2>/dev/null)" == *"dotfiles"* ]]; then
        printf "  ${YELLOW}○${NC} VS Code settings still symlinked to dotfiles\n"
        printf "     ${CYAN}rm ~/Library/Application\\ Support/Code/User/settings.json${NC}\n"
        old=true
    fi
    if ! $old; then
        printf "  ${GREEN}✓${NC} No stale editor configs\n"
    fi

    printf "\n"
}

sub_install() {
    . "$DOTFILES_DIR/install.sh"
}

sub_scaffold() {
    "$DOTFILES_DIR/prompts/scaffold.sh" "$@"
}

sub_profile_shell() {
    printf "${BLUE}%s Profiling shell startup...${NC}\n\n" "$ARROW"
    # Time total startup
    local total
    total=$( { time zsh -i -c exit 2>&1; } 2>&1 | grep real | awk '{print $2}')
    printf "  Total startup time: ${BOLD}%s${NC}\n\n" "$total"

    # Detailed breakdown using zsh XTRACE
    printf "  ${BLUE}Top 10 slowest operations:${NC}\n"
    ZSHRC_PROFILE=1 zsh -i -c exit 2>&1 | \
        awk '{ gsub(/^[0-9]+\.[0-9]+/, "", $0); print }' 2>/dev/null || true

    # Simpler approach: time individual sourced files
    printf "\n  ${BLUE}File-by-file timing:${NC}\n"
    for f in ~/.zshenv ~/.zprofile ~/.zshrc; do
        if [[ -f "$f" ]]; then
            local t
            t=$( { time zsh -c "source $f" 2>/dev/null; } 2>&1 | grep real | awk '{print $2}')
            printf "  %-30s %s\n" "$(basename "$f")" "$t"
        fi
    done
    printf "\n"
    printf "  ${YELLOW}Tip:${NC} If startup is slow, check for heavy evals (fnm env, brew shellenv).\n"
}

sub_completions() {
    cat << 'EOF'
# Zsh completions for dotfiles command
# Add to ~/.zshrc: eval "$(dotfiles completions)"

_dotfiles() {
    local -a commands
    commands=(
        'install:Run full dotfiles setup'
        'help:Show help message'
        'doctor:Check that all tools are installed'
        'update:Update OS, Homebrew, and Node.js'
        'clean:Clean up caches'
        'brew:Run Homebrew setup'
        'dock:Reset macOS Dock'
        'scaffold:Scaffold a new project with AI rules'
        'stale:Find disabled packages still installed'
        'profile-shell:Profile shell startup time'
        'claude-setup:Configure Claude Code plugins and settings'
        'claude-instructions:Update Claude memory file'
        'completions:Output shell completions'
    )
    _describe 'command' commands
}

compdef _dotfiles dotfiles
EOF
}

case $COMMAND_NAME in
    "" | "-h" | "--help")
        sub_help
        ;;
    install)
        sub_install
        ;;
    profile-shell)
        sub_profile_shell
        ;;
    scaffold)
        shift
        sub_scaffold "$@"
        ;;
    claude-setup)
        shift
        sub_claude_setup "$@"
        ;;
    claude-instructions)
        shift
        sub_claude_instructions "$@"
        ;;
    completions)
        sub_completions
        ;;
    doctor)
        sub_doctor
        ;;
    *)
        if declare -f "sub_${COMMAND_NAME}" >/dev/null 2>&1; then
            shift
            "sub_${COMMAND_NAME}" "$@"
        else
            printf "${RED}%s Error: '%s' is not a known command.${NC}\n" "$ARROW" "$COMMAND_NAME" >&2
            sub_help
            exit 1
        fi
        ;;
esac
