#!/usr/bin/env bash

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1

ARROW="￫"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Get dotfiles dir (so run this script from anywhere)
export DOTFILES_DIR EXTRA_DIR
DOTFILES_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && cd .. && pwd )"

sub_help () {
    # Gold-gradient wordmark (banner.py is canonical); never let it break help.
    uv run --project "$DOTFILES_DIR/cli" python -c "from dotfiles.banner import print_banner; print_banner()" 2>/dev/null || true
    printf "%s Usage: ${YELLOW}%s <command>${NC}\n" "$ARROW" "$BIN_NAME"
    printf "\n"
    printf "${BLUE}Core commands:${NC}\n"
    printf "   install              Run full dotfiles setup\n"
    printf "   help                 This help message\n"
    printf "   version              Print version with the gold DOTFILES banner\n"
    printf "   doctor [--fix]       Check all tools are installed (--fix to repair config)\n"
    printf "   update               Update OS, Homebrew, runtimes, and dev tools\n"
    printf "   clean                Clean up Homebrew caches\n"
    printf "   dock                 Reset macOS Dock layout\n"
    printf "   completions          Output shell completions (eval to install)\n"
    printf "   benchmark <cmd>      Benchmark local LM Studio models for your hardware (list|bench|estimate|compare)\n"
    printf "   remote on [opts]       Turn on SSH/Mosh/Zellij access for Termius\n"
    printf "   remote off [opts]      Turn off macOS Remote Login for phone access\n"
    printf "   remote status          Show the remote-shell entrypoint state\n"
    printf "   session|sesh <cmd>     zellij sessions: ls, attach, new, kill, or bare picker\n"
    printf "\n"
    printf "${BLUE}Command center:${NC}\n"
    printf "   tui                    Launch the Mission Control TUI (phone-drivable dashboard)\n"
    printf "   snapshot [ls|diff]     Capture / list / diff machine-state snapshots\n"
    printf "\n"
    printf "${BLUE}Namespaces:${NC}\n"
    printf "   agent setup [opts]   Configure all AI vendors (--reset-mcp to reset managed MCPs)\n"
    printf "   agent overview       Show active agentic setup (Python dashboard)\n"
    printf "   agent migrate-rules-sync [path]\n"
    printf "                        Adopt cross-harness rule sync in an existing project\n"
    printf "   agent web-chat-instructions [--step|--list]\n"
    printf "                        Load advisor prompt into clipboard, chunked for Gemini saved-info\n"
    printf "\n"
    printf "   agent lint           Validate skill/agent files against conventions\n"
    printf "   agent verify [--offline]  Check skills/agents deployed + probe MCP servers\n"
    printf "\n"
    printf "   brew install         Sync packages from packages.toml manifest\n"
    printf "   brew stale           Find disabled packages still installed\n"
    printf "\n"
    printf "   shell profile        Profile shell startup time\n"
    printf "\n"
    printf "   cursor plugins       Show Cursor plugin install checklist\n"
}

sub_update () {
    # shellcheck source=../macos/print_utils.sh
    source "$DOTFILES_DIR/macos/print_utils.sh"

    print_header "Updating everything"

    # --- macOS ---
    print_section "macOS system updates"
    if sudo softwareupdate -i -a 2>&1 | tail -1; then
        print_success "macOS up to date"
    else
        print_warn "macOS update finished with warnings (check above)"
    fi

    # --- Homebrew ---
    print_section "Homebrew (formulae + casks)"
    brew update
    if brew upgrade 2>&1; then
        print_success "Homebrew packages up to date"
    fi
    brew cleanup --prune=30
    print_dim "Cleaned caches older than 30 days"

    # --- Node.js (fnm) ---
    if command -v fnm >/dev/null 2>&1; then
        print_section "Node.js (fnm)"
        eval "$(fnm env)"
        fnm install --lts
        fnm use --install-if-missing lts-latest
        fnm default lts-latest
        print_success "Node.js LTS: $(node --version)"
    fi

    # --- Bun ---
    if command -v bun >/dev/null 2>&1; then
        print_section "Bun"
        bun upgrade
        print_success "Bun: $(bun --version)"
    fi

    # --- Rust (rustup) ---
    if command -v rustup >/dev/null 2>&1; then
        print_section "Rust (rustup)"
        rustup update
        print_success "Rust: $(rustc --version | awk '{print $2}')"
    fi

    # --- UV (Python) ---
    if command -v uv >/dev/null 2>&1; then
        print_section "UV (Python package manager)"
        uv self update
        print_success "UV: $(uv --version)"
    fi

    # --- Global npm packages ---
    if command -v npm >/dev/null 2>&1; then
        print_section "Global npm packages"
        npm update -g
        print_success "Global npm packages updated"
    fi

    # --- Go tools ---
    if command -v go >/dev/null 2>&1; then
        print_section "Go tools"
        local go_tools=(
            "golang.org/x/tools/gopls@latest"
            "github.com/go-delve/delve/cmd/dlv@latest"
            "github.com/air-verse/air@latest"
            "github.com/sqlc-dev/sqlc/cmd/sqlc@latest"
            "github.com/pressly/goose/v3/cmd/goose@latest"
            "github.com/a-h/templ/cmd/templ@latest"
            "honnef.co/go/tools/cmd/staticcheck@latest"
        )
        for tool in "${go_tools[@]}"; do
            local tool_name
            tool_name=$(basename "${tool%%@*}")
            go install "$tool" 2>/dev/null && print_success "$tool_name" || print_warn "Failed: $tool_name"
        done
    fi

    print_completion "All updates finished"
}

sub_clean () {
    # shellcheck source=../macos/print_utils.sh
    source "$DOTFILES_DIR/macos/print_utils.sh"

    print_header "Cleaning up"

    print_section "Homebrew"
    brew cleanup --prune=30
    print_success "Cleared caches older than 30 days"

    print_completion "Cleanup finished"
}

sub_dock () {
    . "$DOTFILES_DIR/macos/dock.sh"
    printf "${GREEN}%b Success! MacOS dock command finished.${NC}\n" "$ARROW"
}

sub_migrate_agents_sync() {
    "$DOTFILES_DIR/ai/agents/migrate-agents-sync.sh" "$@"
}

sub_install() {
    . "$DOTFILES_DIR/install.sh"
}

sub_shell_profile() {
    printf "${BLUE}%b Profiling shell startup...${NC}\n\n" "$ARROW"
    # Time total startup
    local total
    total=$( { time zsh -i -c exit 2>&1; } 2>&1 | grep real | awk '{print $2}')
    printf "  Total startup time: ${BOLD}%s${NC}\n\n" "$total"

    # Detailed breakdown using zsh XTRACE
    printf "  ${BLUE}Top 10 slowest operations:${NC}\n"
    ZSHRC_PROFILE=1 zsh -i -c exit 2>&1 | \
        awk '{ gsub(/^[0-9]+\.[0-9]+/, "", $0); print }' 2>/dev/null || true

    # Simpler approach: time individual sourced files
    printf "\n  ${BLUE}File-by-file timing:${NC}\n"
    for f in ~/.zshenv ~/.zprofile ~/.zshrc; do
        if [[ -f "$f" ]]; then
            local t
            t=$( { time zsh -c "source $f" 2>/dev/null; } 2>&1 | grep real | awk '{print $2}')
            printf "  %-30s %s\n" "$(basename "$f")" "$t"
        fi
    done
    printf "\n"
    printf "  ${YELLOW}Tip:${NC} If startup is slow, check for heavy evals (fnm env, brew shellenv).\n"
}

sub_cursor_plugins() {
    local plugins_file="$DOTFILES_DIR/ai/agents/cursor/PLUGINS.md"
    printf "${BLUE}%b Cursor plugin checklist${NC}\n\n" "$ARROW"
    printf "Run these in Cursor chat (manual install):\n"
    printf "  /add-plugin superpowers\n"
    printf "  /add-plugin context7-plugin\n"
    # Neon plugin disabled 2026-04-09 — revisit when actively using Neon projects
    printf "\nOptional research add-on:\n"
    printf "  /add-plugin parallel\n"
    printf "\nSaaS / team add-ons (when needed):\n"
    printf "  /add-plugin linear\n"
    printf "  /add-plugin datadog\n"
    printf "  /add-plugin slack\n"
    printf "  /add-plugin cloudflare\n"
    printf "  /add-plugin notion-workspace\n"
    if [[ -f "$plugins_file" ]]; then
        printf "\nFull matrix: %s\n" "$plugins_file"
    fi
}

sub_completions() {
    cat << 'EOF'
# Zsh completions for dotfiles command
# Add to ~/.zshrc: eval "$(dotfiles completions)"

_dotfiles() {
    local -a commands
    commands=(
        'install:Run full dotfiles setup'
        'help:Show help message'
        'version:Print version and DOTFILES banner'
        'doctor:Check tools and config (--fix to repair)'
        'update:Update OS, Homebrew, runtimes, and dev tools'
        'clean:Clean caches'
        'dock:Reset macOS Dock'
        'completions:Output shell completions'
        'benchmark:Benchmark local LM Studio models for your hardware'
        'remote:Phone remote-shell access (setup, disable)'
        'session:zellij sessions (ls, attach, new, kill, picker)'
        'sesh:zellij sessions (alias)'
        'tui:Launch the Mission Control TUI'
        'snapshot:Machine-state snapshots (ls, diff)'
        'agent:Agent vendor namespace (overview, lint, setup, verify, web-chat-instructions)'
        'brew:Brew namespace (install, stale)'
        'shell:Shell namespace (profile)'
        'cursor:Cursor namespace (plugins)'
    )
    _describe 'command' commands
}

compdef _dotfiles dotfiles
EOF
}

# --- Namespace dispatchers ---
ns_agent() {
    local sub="${1:-overview}"; shift || true
    case "$sub" in
        migrate-rules-sync) sub_migrate_agents_sync "$@" ;;
        *) printf "${RED}%b Unknown: agent %s${NC} (try: setup, lint, overview, web-chat-instructions)\n" "$ARROW" "$sub" >&2; exit 1 ;;
    esac
}

ns_shell() {
    local sub="${1:-profile}"; shift || true
    case "$sub" in
        profile) sub_shell_profile "$@" ;;
        *) printf "${RED}%b Unknown: shell %s${NC} (try: profile)\n" "$ARROW" "$sub" >&2; exit 1 ;;
    esac
}

ns_cursor() {
    local sub="${1:-plugins}"; shift || true
    case "$sub" in
        plugins) sub_cursor_plugins "$@" ;;
        *) printf "${RED}%b Unknown: cursor %s${NC} (try: plugins)\n" "$ARROW" "$sub" >&2; exit 1 ;;
    esac
}

# Python CLI (P1a + P1b). Migrated commands are delegated to uv run.
# As later phases land, add their names to this list.
# INVARIANT: every name here must also appear in sub_help and sub_completions —
# enforced by cli/tests/test_command_tree.py so the lists can't silently drift.
PY_CLI_COMMANDS=" version remote session sesh doctor benchmark brew snapshot tui "
if [[ -n "${1:-}" && "$PY_CLI_COMMANDS" == *" $1 "* ]]; then
    exec uv run --project "$DOTFILES_DIR/cli" dotfiles "$@"
fi

# Surgical route: agent overview, lint, web-chat-instructions, setup, and verify are Python; others stay Bash.
# Bare `agent` (no subcommand) defaults to overview, matching the old dispatcher.
if [[ "${1:-}" == "agent" ]]; then
    agent_sub="${2:-overview}"
    case "$agent_sub" in
        overview|lint|web-chat-instructions|setup|verify)
            exec uv run --project "$DOTFILES_DIR/cli" dotfiles agent "$agent_sub" "${@:3}" ;;
    esac
fi

case $COMMAND_NAME in
    "" | "-h" | "--help") sub_help ;;

    # Top-level
    install)     sub_install ;;
    update)      sub_update ;;
    clean)       sub_clean ;;
    dock)        sub_dock ;;
    completions) sub_completions ;;
    # Namespaces
    agent)  shift; ns_agent "$@" ;;
    shell)  shift; ns_shell "$@" ;;
    cursor) shift; ns_cursor "$@" ;;

    # Backward-compat aliases for hyphenated names (silent — drop in a future cleanup)
    profile-shell) shift; sub_shell_profile "$@" ;;
    cursor-plugins)  shift; sub_cursor_plugins "$@" ;;

    *)
        if declare -f "sub_${COMMAND_NAME}" >/dev/null 2>&1; then
            shift
            "sub_${COMMAND_NAME}" "$@"
        else
            printf "${RED}%b Error: '%s' is not a known command.${NC}\n" "$ARROW" "$COMMAND_NAME" >&2
            sub_help
            exit 1
        fi
        ;;
esac
