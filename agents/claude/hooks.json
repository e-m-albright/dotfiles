{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); case \"$FILE\" in */.env|*/.env.*|*/credentials*|*id_rsa*|*id_ed25519*) echo 'BLOCK: Sensitive file — edit manually'; exit 2;; esac",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/agents/claude/hooks/format-on-save.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code · $(basename \"$CLAUDE_PROJECT_DIR\")\" -message \"$(cat ~/.claude/agent-status-$PPID 2>/dev/null || echo 'Done — ready for input')\" -sound Glass 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code · $(basename \"$CLAUDE_PROJECT_DIR\")\" -message 'Permission needed' -sound Basso 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
