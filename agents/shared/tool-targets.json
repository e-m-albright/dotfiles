{
  "$comment": "Tool discovery registry — how each AI tool finds .ai/rules/. rootFile entries become symlinks to AGENTS.md",
  "tools": {
    "cursor": {
      "rulesDir": ".cursor/rules",
      "suffix": ".mdc",
      "strategy": "symlink",
      "symlinkPrefix": "../../",
      "rootFile": null,
      "agentsMdAware": false
    },
    "copilot": {
      "rulesDir": ".github/instructions",
      "suffix": ".instructions.md",
      "strategy": "symlink",
      "symlinkPrefix": "../../",
      "rootFile": null,
      "agentsMdAware": true
    },
    "gemini": {
      "rulesDir": ".gemini/rules",
      "suffix": ".md",
      "strategy": "symlink",
      "symlinkPrefix": "../../",
      "rootFile": "GEMINI.md",
      "agentsMdAware": true
    },
    "codex": {
      "rulesDir": null,
      "suffix": null,
      "strategy": "symlink",
      "symlinkPrefix": null,
      "rootFile": "CODEX.md",
      "agentsMdAware": true
    },
    "jules": {
      "$comment": "Cloud-only (jules.google.com) — no local config. Reads AGENTS.md from GitHub repos directly.",
      "rulesDir": null,
      "suffix": null,
      "strategy": null,
      "symlinkPrefix": null,
      "rootFile": null,
      "agentsMdAware": true
    }
  }
}
